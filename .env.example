# Feishu API Configuration
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=your_feishu_app_secret

# Feishu Base (多维表) Configuration
FEISHU_BASE_TOKEN=your_base_token_here
FEISHU_TABLE_ID=your_table_id_here
FEISHU_FOLDER_TOKEN=your_folder_token_here  # 目标文件夹token，用于上传xlsx文件

# Database (optional - defaults to SQLite)
# DATABASE_URL=sqlite:///./data/era.db

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@yourcompany.com
FROM_NAME=ERA 产品体验评估  # 发件人显示名称
EMAIL_CC=hr@yourcompany.com,manager@yourcompany.com  # 抄送邮箱，多个用逗号分隔

# AI Model API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxx
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxx  # 阿里云 DashScope (通义千问)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx    # DeepSeek API
ARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx  # 火山方舟 (豆包模型)

# Webhook Security Token (for Feishu automation)
WEBHOOK_TOKEN=your_secret_token_here

# Application Base URL (for report viewer links in emails)
# Must include https:// protocol prefix
APP_BASE_URL=https://your-domain.com
